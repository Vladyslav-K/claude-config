{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "65000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "300000",
    "CLAUDE_CODE_NO_FLICKER": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "mcp__Framelink_Figma_MCP__get_figma_data",
      "mcp__Framelink_Figma_MCP__download_figma_images",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(ls -*:*)",
      "Bash(grep:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Read(//private/tmp/**)",
      "Bash(echo:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run format:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(npm remove:*)",
      "Bash(npm run format-and-check:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm format-and-check:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run format-and-check:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm remove:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(npm view:*)",
      "Bash(yarn typecheck:*)",
      "Bash(yarn format:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn build:*)",
      "Bash(yarn format-and-check:*)",
      "Bash(yarn run typecheck:*)",
      "Bash(yarn run format:*)",
      "Bash(yarn run lint:*)",
      "Bash(yarn run build:*)",
      "Bash(yarn run format-and-check:*)",
      "Bash(yarn install:*)",
      "Bash(yarn remove:*)"
    ],
    "deny": [
      "Read(./secrets/**)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(chmod 777:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(docker run --privileged:*)",
      "Bash(chmod -R:*)",
      "Bash(curl | sh:*)",
      "Bash(curl*| sh:*)",
      "Bash(curl*| bash:*)",
      "Bash(wget*| sh:*)",
      "Bash(wget*| bash:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(> /dev/sd*:*)",
      "Bash(git push --force:*)",
      "Bash(--dangerously-skip-permissions:*)",
      "Bash(git clean -fd:*)",
      "Bash(git restore .:*)",
      "Bash(git checkout -- .:*)",
      "Bash(docker run -v /:/:*)",
      "Bash(eval:*)",
      "Bash(git push --force-with-lease:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/scripts/prompt-inject.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || printf '\\a'"
          },
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/scripts/stop-check.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/scripts/session-start.sh"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/scripts/post-compact.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "{{CLAUDE_HOME}}/scripts/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-code-plugins": true
  },
  "outputStyle": "Explanatory",
  "language": "Ukrainian",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754036467609
  },
  "tui": "fullscreen"
}
