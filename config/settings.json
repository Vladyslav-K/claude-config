{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skillListingBudgetFraction": 0.05,
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "65000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "300000",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(ls -*:*)",
      "Bash(grep:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(jq:*)",
      "Bash(cat:*)",
      "Read(//private/tmp/**)",
      "Bash(echo:*)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run format:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(npm remove:*)",
      "Bash(npm run format-and-check:*)",
      "Bash(npm exec:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm format-and-check:*)",
      "Bash(pnpm run typecheck:*)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run build:*)",
      "Bash(pnpm run format-and-check:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm exec:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(npm view:*)",
      "Bash(yarn typecheck:*)",
      "Bash(yarn format:*)",
      "Bash(yarn lint:*)",
      "Bash(yarn build:*)",
      "Bash(yarn format-and-check:*)",
      "Bash(yarn run typecheck:*)",
      "Bash(yarn run format:*)",
      "Bash(yarn run lint:*)",
      "Bash(yarn run build:*)",
      "Bash(yarn run format-and-check:*)",
      "Bash(yarn install:*)",
      "Bash(yarn remove:*)",
      "Bash(yarn exec:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh issue view:*)"
    ],
    "deny": [
      "Read(./secrets/**)",
      "Bash(sudo:*)",
      "Bash(git reset:*)",
      "Bash(chmod 777:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(docker run --privileged:*)",
      "Bash(chmod -R:*)",
      "Bash(curl | sh:*)",
      "Bash(curl*| sh:*)",
      "Bash(curl*| bash:*)",
      "Bash(wget*| sh:*)",
      "Bash(wget*| bash:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(> /dev/sd*:*)",
      "Bash(git push --force:*)",
      "Bash(--dangerously-skip-permissions:*)",
      "Bash(git clean -fd:*)",
      "Bash(git restore .:*)",
      "Bash(git checkout -- .:*)",
      "Bash(docker run -v /:/:*)",
      "Bash(eval:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/scripts/prompt-inject.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty 2>/dev/null || printf '\\a'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "{{CLAUDE_HOME}}/scripts/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-code-plugins": true
  },
  "outputStyle": "Explanatory",
  "language": "Ukrainian",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true,
  "editorMode": "normal",
  "preferredNotifChannel": "terminal_bell",
  "autoCompactEnabled": false,
  "terminalProgressBarEnabled": false,
  "teammateMode": "tmux",
  "remoteControlAtStartup": false,
  "useAutoModeDuringPlan": false,
  "feedbackSurveyState": {
    "lastShownTime": 1754036467609
  }
}
